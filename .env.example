# Banco de dados Postgres (gratuito em provedores como neon.com ou supabase.com).
# Copie a "connection string" fornecida pelo provedor e cole aqui.
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/nomedobanco?sslmode=require"

# NextAuth
# Gere um valor com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-um-valor-aleatorio-seguro"
# Em produção, use a URL pública do seu deploy (ex: https://seu-projeto.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
