// Banco: Postgres (gratuito em provedores como Neon ou Supabase).
// Necessário para deploy em hospedagens serverless como a Vercel ou o Netlify, onde
// um arquivo SQLite local não persistiria entre deploys/execuções.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  companies Company[]
  createdAt DateTime  @default(now())
}

model Company {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#D4AF37")
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String
  tasks     Task[]
  createdAt DateTime @default(now())
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String     @default("")
  date        DateTime
  status      TaskStatus @default(TODO)
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
